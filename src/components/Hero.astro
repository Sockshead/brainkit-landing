---
import { SLOTS_AVAILABLE, STRIPE_KICKSTART_LINK } from '../config/site';
---

<section class="relative min-h-screen flex flex-col items-center justify-center px-4 py-24 text-center overflow-hidden">

  <div class="hero-glow absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-3xl mx-auto">

    <!-- Category pill -->
    <div class="inline-flex items-center gap-2 border border-amber-400/30 bg-amber-400/10 text-amber-400 text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-full mb-8">
      <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
      </svg>
      AI knowledge system &mdash; done for you
    </div>

    <!-- Headline -->
    <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold text-zinc-100 leading-tight mb-6">
      Your AI assistant<br />
      that actually<br />
      <em class="not-italic text-amber-400">knows you.</em>
    </h1>

    <!-- Subhead -->
    <p class="text-zinc-400 text-lg sm:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
      For consultants, coaches, and founders.
      A custom knowledge system built around your work — then kept current every month.
    </p>

    <!-- CTA block -->
    <div class="flex flex-col items-center gap-4 mb-10">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 w-full sm:w-auto">
        <a
          href={STRIPE_KICKSTART_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-amber-400 text-zinc-950 font-semibold px-8 py-3.5 rounded-lg hover:bg-amber-300 transition-colors w-full sm:w-auto text-center cursor-pointer"
        >
          Get your system built &mdash; $197 &rarr;
        </a>
        <a
          href="#pricing"
          class="border border-zinc-700 text-zinc-300 px-8 py-3.5 rounded-lg hover:border-zinc-500 transition-colors w-full sm:w-auto text-center cursor-pointer"
        >
          See pricing &darr;
        </a>
      </div>

      <!-- Privacy signal -->
      <p class="flex items-center gap-2 text-zinc-500 text-xs">
        <svg class="w-3.5 h-3.5 text-zinc-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        Your vault stays on your Mac. Your data is never used for training.
      </p>
    </div>

    <!-- Scarcity -->
    <p class="text-amber-400 text-sm font-medium">
      <span class="inline-block w-2 h-2 rounded-full bg-amber-400 mr-2 align-middle animate-pulse" aria-hidden="true"></span>
      {SLOTS_AVAILABLE} intro spots remaining &mdash; first 3 clients only
    </p>

  </div>
</section>

<style>
  .hero-glow {
    background: radial-gradient(ellipse 100% 55% at 50% -5%, rgba(251, 191, 36, 0.07), transparent 70%);
  }
</style>
