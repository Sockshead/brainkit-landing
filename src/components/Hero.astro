---
import { SLOTS_AVAILABLE, CAL_LINK, STRIPE_KICKSTART_LINK } from '../config/site';
---

<section class="relative min-h-screen flex flex-col items-center justify-center px-4 py-24 text-center overflow-hidden">

  <!-- Warm amber glow — atmosphere, not noise -->
  <div class="hero-glow absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-3xl mx-auto">

    <!-- Voice-to-Vault feature pill — #1 moat, above the headline -->
    <div class="inline-flex items-center gap-2 border border-amber-400/30 bg-amber-400/10 text-amber-400 text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-full mb-8">
      <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 016 0v6a3 3 0 01-3 3z" />
      </svg>
      Voice &rarr; Vault &mdash; speak, it files itself
    </div>

    <!-- Headline: scan stops here -->
    <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold text-zinc-100 leading-tight mb-6">
      Your AI assistant<br />
      that actually<br />
      <em class="not-italic text-amber-400">knows you.</em>
    </h1>

    <!-- Subhead: who it's for + what you get -->
    <p class="text-zinc-400 text-lg sm:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
      For consultants, coaches, and founders.
      A custom knowledge system built around your work — then kept current every month.
    </p>

    <!-- CTA block -->
    <div class="flex flex-col items-center gap-4 mb-10">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 w-full sm:w-auto">
        <a
          href={STRIPE_KICKSTART_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-amber-400 text-zinc-950 font-semibold px-8 py-3.5 rounded-lg hover:bg-amber-300 transition-colors w-full sm:w-auto text-center cursor-pointer"
        >
          Get your system built &mdash; $197 &rarr;
        </a>
        <a
          href={`https://cal.com/${CAL_LINK}`}
          target="_blank"
          rel="noopener noreferrer"
          class="border border-zinc-700 text-zinc-300 px-8 py-3.5 rounded-lg hover:border-zinc-500 transition-colors w-full sm:w-auto text-center cursor-pointer"
        >
          Book a discovery call &darr;
        </a>
      </div>

      <!-- Privacy signal: inline, near the CTA — not a footnote -->
      <p class="flex items-center gap-2 text-zinc-500 text-xs">
        <svg class="w-3.5 h-3.5 text-zinc-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        Your vault stays on your Mac. Your data is never used for training.
      </p>

      <!-- Role-picker: warm lead capture via mailto -->
      <div class="flex flex-col items-center gap-2 mt-2">
        <p class="text-zinc-600 text-xs">Tell us your role and get a sample CLAUDE.md in your inbox:</p>
        <div class="flex flex-wrap justify-center gap-2">
          <a
            href={`mailto:johannes@brainkit.so?subject=${encodeURIComponent("BrainKit — Coach")}&body=${encodeURIComponent("Hi Johannes,\n\nI'm a coach and I'm interested in BrainKit.\n\nI'd love to see a sample CLAUDE.md for my setup.\n\n---\nName:\nType of coaching:\nTools I currently use:\n")}`}
            class="text-xs px-3 py-1.5 rounded-full border border-zinc-700 text-zinc-500 hover:border-zinc-500 hover:text-zinc-300 transition-colors"
          >
            I'm a coach
          </a>
          <a
            href={`mailto:johannes@brainkit.so?subject=${encodeURIComponent("BrainKit — Consultant")}&body=${encodeURIComponent("Hi Johannes,\n\nI'm a consultant and I'm interested in BrainKit.\n\nI'd love to see a sample CLAUDE.md for my setup.\n\n---\nName:\nType of consulting:\nActive clients (approx):\n")}`}
            class="text-xs px-3 py-1.5 rounded-full border border-zinc-700 text-zinc-500 hover:border-zinc-500 hover:text-zinc-300 transition-colors"
          >
            I'm a consultant
          </a>
          <a
            href={`mailto:johannes@brainkit.so?subject=${encodeURIComponent("BrainKit — Founder")}&body=${encodeURIComponent("Hi Johannes,\n\nI'm a founder and I'm interested in BrainKit.\n\nI'd love to see a sample CLAUDE.md for my setup.\n\n---\nName:\nStage/team size:\nBiggest knowledge management pain:\n")}`}
            class="text-xs px-3 py-1.5 rounded-full border border-zinc-700 text-zinc-500 hover:border-zinc-500 hover:text-zinc-300 transition-colors"
          >
            I'm a founder
          </a>
        </div>
      </div>
    </div>

    <!-- Scarcity indicator -->
    <p class="text-amber-400 text-sm font-medium">
      <span class="inline-block w-2 h-2 rounded-full bg-amber-400 mr-2 align-middle animate-pulse" aria-hidden="true"></span>
      {SLOTS_AVAILABLE} intro spots remaining &mdash; first 3 clients only
    </p>

  </div>
</section>

<style>
  .hero-glow {
    background: radial-gradient(ellipse 100% 55% at 50% -5%, rgba(251, 191, 36, 0.07), transparent 70%);
  }
</style>
