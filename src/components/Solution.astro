---
const steps = [
  {
    number: "1",
    title: "We build your system",
    body: "CLAUDE.md written specifically for your work. Your projects, your clients, your routing rules. Not a template — your actual workflow.",
  },
  {
    number: "2",
    title: "You talk, it listens",
    body: "Send voice notes via Telegram. Your AI routes them to the right project, files meeting notes, captures ideas. No laptop required.",
  },
  {
    number: "3",
    title: "We keep it current",
    body: "Every month: CLAUDE.md audited and updated as your work evolves. Brain Report sent. New AI capabilities applied. Your system gets smarter, not staler.",
  },
];

const queries = [
  "What did I discuss with Sarah last week?",
  "Summarize everything I captured about Project X",
  "What tasks did I commit to this month?",
];

const rolePreviews = {
  coach: `# CLAUDE.md — Executive Coach

## Routing Table
- Client session notes  →  Clients/{{name}}/Sessions/YYYY-MM-DD.md
- Action items          →  Clients/{{name}}/Actions.md
- Confidential content  →  never committed to git

## Context
I coach senior leaders at growth-stage companies.
Sessions are 60–90 min weekly. Prioritize: client
accountability, session continuity, confidentiality.

## Daily Workflow
Morning   → Route overnight inbox captures
Post-call → File session notes within 2 hours
Friday    → Review all open actions across clients`,

  consultant: `# CLAUDE.md — Independent Consultant

## Routing Table
- Client files     →  Clients/{{CompanyName}}/
- Project briefs   →  Clients/{{name}}/Brief.md
- Meeting notes    →  Clients/{{name}}/Meetings/YYYY-MM-DD.md
- Proposals        →  Pipeline/{{company}}-Proposal.md

## Active Clients (update monthly)
| Client   | Status | Next deliverable    |
|----------|--------|---------------------|
| Acme     | Active | Strategy deck, Apr 1|
| Globex   | Active | Workshop, Apr 15    |

## Context
3–5 concurrent engagements. Prioritize by deadline.`,

  founder: `# CLAUDE.md — Founder

## Routing Table
- Investor updates  →  Investors/{{name}}/Updates/
- Pilot feedback    →  Pilots/{{company}}/Feedback.md
- Decisions         →  Decisions/YYYY-MM-DD-{{title}}.md
- Team context      →  Team/{{name}}.md

## Current Focus
Raising pre-seed. 3 active pilots. Team of 4.

## Decision Log Protocol
Every major decision: context, options considered,
chosen path, rationale. File same day.`,
};
---

<section class="py-24 px-4 bg-zinc-900/30">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-zinc-100 text-center mb-6">
      An AI that knows you. And stays that way.
    </h2>

    <p class="text-center text-zinc-400 mb-16 max-w-xl mx-auto">
      Not a template. Not a course. A fully built, maintained AI knowledge system — delivered to your Mac.
    </p>

    <!-- Steps: horizontal on desktop, vertical on mobile -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 relative">
      <!-- Connector line (desktop only) -->
      <div class="hidden md:block absolute top-8 left-[calc(16.66%+1rem)] right-[calc(16.66%+1rem)] h-px bg-zinc-800 z-0"></div>

      <!-- Connector line (mobile only) -->
      <div class="md:hidden absolute left-6 top-10 bottom-10 w-px bg-zinc-800 z-0"></div>

      {steps.map((step) => (
        <div class="relative flex flex-col items-start md:items-center text-left md:text-center gap-4 z-10">
          <div class="w-12 h-12 rounded-full bg-amber-400 text-zinc-950 font-display font-bold text-lg flex items-center justify-center shrink-0">
            {step.number}
          </div>
          <div>
            <h3 class="text-zinc-100 font-semibold text-lg mb-2">{step.title}</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">{step.body}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Terminal-style blockquote -->
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 font-mono text-sm max-w-2xl mx-auto mb-16">
      <p class="text-zinc-500 mb-3 text-xs uppercase tracking-wider">Ask your AI anything</p>
      {queries.map((q) => (
        <div class="flex items-start gap-3 mb-2 last:mb-0">
          <span class="text-amber-400 select-none shrink-0">&gt;</span>
          <span class="text-zinc-300">{q}</span>
        </div>
      ))}
    </div>

    <!-- Role-picker: shows what your CLAUDE.md actually looks like -->
    <div class="max-w-2xl mx-auto">
      <p class="text-center text-zinc-500 text-xs uppercase tracking-wider mb-5">See a real CLAUDE.md — pick your role</p>

      <div class="flex justify-center gap-3 mb-6" id="role-tabs">
        <button data-role="coach" class="role-btn px-4 py-2 rounded-lg text-sm font-medium transition-all border border-amber-400 text-amber-400">
          Coach
        </button>
        <button data-role="consultant" class="role-btn px-4 py-2 rounded-lg text-sm font-medium transition-all border border-zinc-700 text-zinc-400 hover:border-zinc-500">
          Consultant
        </button>
        <button data-role="founder" class="role-btn px-4 py-2 rounded-lg text-sm font-medium transition-all border border-zinc-700 text-zinc-400 hover:border-zinc-500">
          Founder
        </button>
      </div>

      <div class="bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-zinc-800 bg-zinc-950/50">
          <span class="w-3 h-3 rounded-full bg-zinc-700"></span>
          <span class="w-3 h-3 rounded-full bg-zinc-700"></span>
          <span class="w-3 h-3 rounded-full bg-zinc-700"></span>
          <span class="ml-2 text-zinc-600 text-xs font-mono" id="role-filename">CLAUDE.md — Coach</span>
        </div>
        <pre id="role-preview" class="p-5 font-mono text-xs text-zinc-300 leading-relaxed overflow-x-auto whitespace-pre">{rolePreviews.coach}</pre>
      </div>

      <p class="text-center text-zinc-600 text-xs mt-4">This is exactly what gets built for you — tailored to your workflow, not a copy-paste template.</p>
    </div>

  </div>
</section>

<script>
  const previews: Record<string, string> = {
    coach: document.getElementById('role-preview')?.textContent ?? '',
    consultant: `# CLAUDE.md — Independent Consultant\n\n## Routing Table\n- Client files     →  Clients/{{CompanyName}}/\n- Project briefs   →  Clients/{{name}}/Brief.md\n- Meeting notes    →  Clients/{{name}}/Meetings/YYYY-MM-DD.md\n- Proposals        →  Pipeline/{{company}}-Proposal.md\n\n## Active Clients (update monthly)\n| Client   | Status | Next deliverable    |\n|----------|--------|---------------------|\n| Acme     | Active | Strategy deck, Apr 1|\n| Globex   | Active | Workshop, Apr 15    |\n\n## Context\n3–5 concurrent engagements. Prioritize by deadline.`,
    founder: `# CLAUDE.md — Founder\n\n## Routing Table\n- Investor updates  →  Investors/{{name}}/Updates/\n- Pilot feedback    →  Pilots/{{company}}/Feedback.md\n- Decisions         →  Decisions/YYYY-MM-DD-{{title}}.md\n- Team context      →  Team/{{name}}.md\n\n## Current Focus\nRaising pre-seed. 3 active pilots. Team of 4.\n\n## Decision Log Protocol\nEvery major decision: context, options considered,\nchosen path, rationale. File same day.`,
  };

  const filenames: Record<string, string> = {
    coach: 'CLAUDE.md — Coach',
    consultant: 'CLAUDE.md — Consultant',
    founder: 'CLAUDE.md — Founder',
  };

  const tabContainer = document.getElementById('role-tabs');
  const preview = document.getElementById('role-preview');
  const filename = document.getElementById('role-filename');

  tabContainer?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-role]') as HTMLElement | null;
    if (!btn) return;
    const role = btn.dataset.role ?? 'coach';

    tabContainer.querySelectorAll('.role-btn').forEach((b) => {
      b.classList.remove('border-amber-400', 'text-amber-400');
      b.classList.add('border-zinc-700', 'text-zinc-400');
    });
    btn.classList.add('border-amber-400', 'text-amber-400');
    btn.classList.remove('border-zinc-700', 'text-zinc-400');

    if (preview) preview.textContent = previews[role] ?? '';
    if (filename) filename.textContent = filenames[role] ?? '';
  });
</script>
