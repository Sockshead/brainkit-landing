---
import { CAL_LINK, INTRO_PRICE, REGULAR_PRICE, STRIPE_KICKSTART_LINK } from '../config/site';
---

<section id="pricing" class="py-24 px-4">
  <div class="max-w-5xl mx-auto">

    <h2 class="font-display text-3xl sm:text-4xl font-bold text-zinc-100 text-center mb-4">
      Simple, transparent pricing.
    </h2>
    <p class="text-zinc-400 text-center mb-16">
      One-time setup + optional monthly maintenance. No surprises.
    </p>

    <!-- Main 3-tier grid: Kickstart · Concierge · Full Stack -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10 items-start">

      <!-- Kickstart -->
      <div class="bg-zinc-900 rounded-xl p-6 flex flex-col border border-zinc-800">
        <div class="mb-6">
          <h3 class="text-zinc-100 font-semibold text-lg mb-2">Kickstart</h3>
          <div class="flex items-baseline gap-2 mb-1">
            <span class="font-display text-4xl font-bold text-zinc-100">${INTRO_PRICE}</span>
            <span class="text-zinc-400 text-sm">intro</span>
            <span class="text-zinc-600 text-sm">&rarr; ${REGULAR_PRICE} regular</span>
          </div>
          <p class="text-zinc-500 text-xs mb-2">One-time. First 3 clients only.</p>
          <p class="text-zinc-400 text-sm">Johannes configures your setup. You own it after.</p>
        </div>
        <ul class="flex flex-col gap-3 mb-6 flex-1">
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            CLAUDE.md written from intake form
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            60-min onboarding call
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            You own it — no retainer required
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-600">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" /></svg>
            No voice pipeline
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-600">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" /></svg>
            No monthly maintenance
          </li>
        </ul>
        <a
          href={STRIPE_KICKSTART_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="text-center font-semibold px-6 py-3 rounded-lg transition-colors bg-amber-400 text-zinc-950 hover:bg-amber-300 cursor-pointer"
        >
          Get started &mdash; $197 &rarr;
        </a>
      </div>

      <!-- Concierge (highlighted) -->
      <div class="relative bg-zinc-900 rounded-xl py-10 px-6 flex flex-col border border-amber-400 shadow-[0_0_40px_rgba(251,191,36,0.12)]">
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
          <span class="bg-amber-400 text-zinc-950 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
            Most popular
          </span>
        </div>

        <div class="mb-6">
          <h3 class="text-zinc-100 font-semibold text-lg mb-2">Concierge</h3>
          <div class="flex items-baseline gap-2 mb-2">
            <span class="font-display text-4xl font-bold text-zinc-100">$247</span>
            <span class="text-zinc-400 text-sm">/mo</span>
          </div>
          <p class="text-zinc-400 text-sm">Full setup + monthly maintenance. Min 3 months.</p>
        </div>
        <ul class="flex flex-col gap-3 mb-6 flex-1">
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Full setup included in month 1
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Monthly: CLAUDE.md audit + Brain Report + upgrades
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Voice-to-vault setup in week 5
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Private git backup
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Cancel with 30-day notice
          </li>
        </ul>
        <a
          href={`https://cal.com/${CAL_LINK}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-center font-semibold px-6 py-3 rounded-lg transition-colors bg-amber-400 text-zinc-950 hover:bg-amber-300 cursor-pointer"
        >
          Book a call &rarr;
        </a>
      </div>

      <!-- Full Stack -->
      <div class="bg-zinc-900 rounded-xl p-6 flex flex-col border border-zinc-800">
        <div class="mb-6">
          <h3 class="text-zinc-100 font-semibold text-lg mb-2">Full Stack</h3>
          <div class="flex items-baseline gap-2 mb-2">
            <span class="font-display text-4xl font-bold text-zinc-100">$497</span>
            <span class="text-zinc-400 text-sm">+ $247/mo</span>
          </div>
          <p class="text-zinc-400 text-sm">Everything on day 1. 3 months Concierge included.</p>
        </div>
        <ul class="flex flex-col gap-3 mb-6 flex-1">
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Voice pipeline live in month 1
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            3 months Concierge included
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Everything in Concierge
          </li>
          <li class="flex items-start gap-2 text-sm text-zinc-300">
            <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            No waiting — full system from day 1
          </li>
        </ul>
        <a
          href={`https://cal.com/${CAL_LINK}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-center font-semibold px-6 py-3 rounded-lg transition-colors border border-zinc-700 text-zinc-200 hover:border-zinc-500 cursor-pointer"
        >
          Book a call &rarr;
        </a>
      </div>

    </div>

    <!-- Discovery call note -->
    <p class="text-center text-zinc-500 text-sm max-w-xl mx-auto mb-10">
      Concierge and Full Stack start with a 20-minute discovery call to scope your workflow before we build anything.
    </p>

    <!-- Free tier: ghost row — de-emphasized, below the funnel -->
    <div class="border-t border-zinc-800 pt-8 text-center">
      <p class="text-zinc-600 text-sm">
        Prefer to build it yourself?
        <a
          href="https://github.com/sockshead/brainkit-starter"
          target="_blank"
          rel="noopener noreferrer"
          class="text-zinc-500 underline underline-offset-2 hover:text-zinc-300 transition-colors ml-1"
        >
          Fork the OSS template on GitHub &rarr;
        </a>
      </p>
      <p class="text-zinc-700 text-xs mt-1">Free. Most engineers spend 4&ndash;6 hours on first setup. The routing table is where it falls apart.</p>
    </div>

  </div>
</section>
