---
import { CAL_LINK } from '../config/site';
---

<section class="py-24 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-zinc-100 text-center mb-4">
      What clients say
    </h2>
    <p class="text-zinc-500 text-center text-sm mb-12">
      Currently accepting first clients. Testimonials will appear here.
    </p>

    <div class="flex justify-center">
      <div class="border border-dashed border-zinc-700 rounded-xl p-8 max-w-sm w-full text-center">
        <div class="w-12 h-12 rounded-full bg-zinc-800 mx-auto mb-4 flex items-center justify-center">
          <span class="text-zinc-500 text-xl">?</span>
        </div>
        <p class="text-zinc-500 text-sm italic mb-4">
          "Be one of the first 3 clients. Kickstart at intro price — $197 instead of $297."
        </p>
        <a
          href={`https://cal.com/${CAL_LINK}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-amber-400 text-sm hover:text-amber-300 transition"
        >
          Book a discovery call to be one of our first clients &rarr;
        </a>
      </div>
    </div>
  </div>
</section>
